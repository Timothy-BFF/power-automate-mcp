# ══════════════════════════════════════════════════════════════
# Power Automate MCP — Environment Variables (v3.0.0)
# ══════════════════════════════════════════════════════════════

# ── Simtheory Gateway ──────────────────────────────────────────
SIMTHEORY_AUTH_TOKEN=

# ── Service Principal (READ operations — existing v2.4.0) ─────
# Used for: pa-list-flows, pa-get-flow-details, pa-get-run-history, etc.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Delegated User Auth (WRITE operations — new v3.0.0) ───────
# Separate Azure AD App Registration for Device Code Flow.
# Used for: pa-create-flow, pa-update-flow, pa-delete-flow, etc.
# If not set, write operations will be unavailable.
PA_USER_CLIENT_ID=
PA_USER_TENANT_ID=

# ── Power Platform ─────────────────────────────────────────────
POWER_AUTOMATE_ENVIRONMENT_ID=

# ── Server ─────────────────────────────────────────────────────
PORT=3000
