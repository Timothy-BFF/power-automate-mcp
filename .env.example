# ═══════════════════════════════════════════════════════
# Power Automate MCP Server — Environment Variables
# ═══════════════════════════════════════════════════════

# Server
PORT=8080
LOG_LEVEL=info

# Simtheory.ai Authorization
SIMTHEORY_AUTH_TOKEN=your_simtheory_token_here

# Azure AD Application Registration
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret

# Power Platform Configuration
# Default environment ID (optional — tools can override per-call)
POWER_PLATFORM_ENVIRONMENT_ID=your_default_environment_id

# Azure AD Scopes (usually don't need to change these)
AZURE_FLOW_SCOPE=https://service.flow.microsoft.com/.default
AZURE_MANAGEMENT_SCOPE=https://management.azure.com/.default
